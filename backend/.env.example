# Council backend environment
# Copy to .env for local `go run ./cmd/server` or `docker compose up`.

# Required, fails fast at startup if missing. Never commit the real value.
ZAI_API_KEY=your-zai-api-key-here

# Optional, defaults to :8080. docker-compose.yml overrides this to :10000
# to match backend/Dockerfile's EXPOSE and render.yaml's production config.
BACKEND_ADDR=:8080

# Optional, comma-separated allowlist of frontend origins for CORS/WS checks.
# Defaults to localhost:5173, matching both the Vite dev server and the
# docker-compose frontend service's published host port.
FRONTEND_ORIGINS=localhost:5173

# Optional, defaults to glm-4.7.
LLM_MODEL=glm-4.7
